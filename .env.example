# Database (Railway PostgreSQL - will be auto-provided in Railway dashboard)
DATABASE_URL="postgresql://user:password@host:5432/database"

# Clerk Auth (get from https://dashboard.clerk.com)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY="your_clerk_publishable_key"
CLERK_SECRET_KEY="your_clerk_secret_key"

# Mailgun (for email webhooks)
MAILGUN_API_KEY="your_mailgun_api_key"
MAILGUN_DOMAIN="your_mailgun_domain"
MAILGUN_SENDER_EMAIL="noreply@your_mailgun_domain"

# OpenAI (for invoice extraction)
OPENAI_API_KEY="your_openai_api_key"

# Stripe (backend only - no frontend keys needed since @stripe/react-stripe-js removed)
STRIPE_SECRET_KEY="your_stripe_secret_key"
STRIPE_WEBHOOK_SECRET="your_stripe_webhook_secret"

# Supabase (for file storage)
NEXT_PUBLIC_